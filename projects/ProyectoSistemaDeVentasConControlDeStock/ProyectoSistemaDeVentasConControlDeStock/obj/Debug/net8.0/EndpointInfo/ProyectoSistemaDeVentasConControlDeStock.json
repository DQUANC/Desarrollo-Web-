{
  "openapi": "3.0.1",
  "info": {
    "title": "ProyectoSistemaDeVentasConControlDeStock",
    "version": "1.0"
  },
  "paths": {
    "/api/Producto/ObtenerTodos": {
      "get": {
        "tags": [
          "Producto"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "applications/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProductoModel"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProductoModel": {
        "required": [
          "nombre_producto",
          "precio",
          "stock"
        ],
        "type": "object",
        "properties": {
          "skU_producto": {
            "type": "integer",
            "format": "int32"
          },
          "nombre_producto": {
            "minLength": 1,
            "type": "string"
          },
          "precio": {
            "type": "number",
            "format": "double"
          },
          "stock": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  }
}